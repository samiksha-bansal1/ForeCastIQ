# ForecastIQ Backend — copy this to .env and fill in your values

# Google Gemini API key — free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
# Flask environment — set to "production" when deploying
FLASK_ENV=development

# Flask secret key — any random string; change in production
FLASK_SECRET_KEY=change_this_to_a_random_string

# Frontend URL for CORS — change if your frontend runs on a different port
FRONTEND_URL=http://localhost:3000
