# ForecastIQ Backend — copy to .env and fill in values

# Gemini — primary AI (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq — automatic fallback if Gemini fails (free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change_this_to_a_random_string

# CORS
FRONTEND_URL=http://localhost:3000